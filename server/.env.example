# Configuración del Puerto del Servidor Backend
PORT=3000

# URL de Conexión de la Base de Datos PostgreSQL
# Reemplazar con los datos de tu Google Cloud SQL en producción, o PostgreSQL local para desarrollo.
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/produccion_erp

# Clave Secreta para Tokens JWT de Autenticación
JWT_SECRET=reemplazar_con_una_cadena_larga_y_segura_de_produccion

# Clave de API de Google AI Studio (Gemini API Key)
# Consíguela en: https://aistudio.google.com/
GEMINI_API_KEY=tu_clave_de_api_de_google_ai_studio_aquiasdsad
